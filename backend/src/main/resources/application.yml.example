# PawMatch 后端 application.yml 模板（占位符版本）
# 复制为 src/main/resources/application.yml，并填入你的真实配置 / 环境变量
#
# 推荐做法：
#   1) 本地开发：在 backend/ 下建一个 .env 文件，写入真实密钥，启动时由 IDE / shell 注入
#   2) 生产环境：用 K8s Secret / Vault / SealedSecrets 注入
#   3) 本文件中的所有 ${VAR:default} 形式，default 都已置空或为公开占位符

server:
  port: 8081
  servlet:
    encoding:
      charset: UTF-8
      force: true

spring:
  application:
    name: pawmatch

  servlet:
    multipart:
      max-file-size: 10MB
      max-request-size: 20MB

  datasource:
    url: jdbc:postgresql://localhost:5433/pawmatch
    username: postgres
    password: ${SPRING_DATASOURCE_PASSWORD:}
    driver-class-name: org.postgresql.Driver

  flyway:
    enabled: true
    baseline-on-migrate: true
    locations: classpath:db/migration
    table: flyway_schema_history

  sql:
    init:
      mode: never

  data:
    redis:
      host: localhost
      port: 6379
      password: ${REDIS_PASSWORD:}

  rabbitmq:
    host: localhost
    port: 5672
    username: guest
    password: ${SPRING_RABBITMQ_PASSWORD:guest}
    virtual-host: /
    listener:
      simple:
        acknowledge-mode: manual
        prefetch: 1
        retry:
          enabled: false

  ai:
    # DashScope（阿里云百炼/MAAS）：必填
    dashscope:
      api-key: ${DASHSCOPE_API_KEY:}
    # 业务层 ChatClient/EmbeddingModel 走 OpenAI 兼容协议（硅基流动 / OpenAI 等）
    openai:
      api-key: ${OPENAI_API_KEY:}
      base-url: ${OPENAI_BASE_URL:https://api.siliconflow.cn}
      chat:
        options:
          model: ${OPENAI_CHAT_MODEL:Pro/MiniMaxAI/MiniMax-M2.5}
      embedding:
        options:
          model: ${OPENAI_EMBEDDING_MODEL:BAAI/bge-m3}

mybatis-plus:
  configuration:
    map-underscore-to-camel-case: true
    log-impl: org.apache.ibatis.logging.stdout.StdOutImpl
  global-config:
    db-config:
      id-type: auto
      logic-delete-field: deleted
      logic-delete-value: 1
      logic-not-delete-value: 0

jwt:
  # 至少 256 bit（32 字节），建议 `openssl rand -hex 32` 生成
  secret: ${JWT_SECRET:}
  expiration: 86400000

# Embedding 配置（pgvector 对齐 BAAI/bge-m3 实际输出）
embedding:
  model: BAAI/bge-m3
  dimension: 1024

# 匹配权重（架构要求 6 维；向量相似度作为先验不占权重）
matching:
  weights:
    personality_match: 0.30
    size_preference: 0.25
    experience_match: 0.20
    activity_match: 0.15
    health_status: 0.10
  reason:
    llm-enabled: true

# 知识库 ETL 配置
knowledge:
  chunk-size: 512
  chunk-overlap: 50

# 意图识别（LLM 优先 + 关键词 fallback）
intent:
  llm-enabled: true

# CORS 白名单
cors:
  allowed-origins:
    - http://localhost:5173
    - http://localhost:5174
    - http://localhost:3000

# 阿里云 OSS：所有文件上传 / 删除统一走 OSS
aliyun:
  oss:
    endpoint: ${ALI_OSS_ENDPOINT:}
    access-key-id: ${ALI_OSS_ACCESS_KEY_ID:}
    access-key-secret: ${ALI_OSS_ACCESS_KEY_SECRET:}
    bucket-name: ${ALI_OSS_BUCKET_NAME:}
    url-prefix: ${ALI_OSS_URL_PREFIX:}
    key-prefix: ${ALI_OSS_KEY_PREFIX:pawmatch/}

# PawMatch 业务配置（W1 Day 5：电子协议 PDF 存储）
pawmatch:
  agreement:
    storage-dir: ${PAWMATCH_AGREEMENT_DIR:${user.home}/pawmatch/agreements}
    template-version: v1.0
  booking:
    voucher-prefix: BK
    auto-confirm-seconds: 5
    optimistic-lock-retry: 3