# PawMatch 后端 .env 模板（本地用，不会被 git 追踪）
#
# 用法：
#   1) 复制本文件为 .env：  cp .env.example .env
#   2) 把下面所有 "xxx" / "sk-..." / "LTAI..." 替换成你自己的真实密钥
#   3) 启动：bash run.sh   （会自动 source 本文件）
#
# 注意：
#   - 本文件已被 .gitignore 忽略，绝不会上传到 GitHub
#   - 不要把真实的 .env 文件 commit 进来
#   - 生产环境请用 K8s Secret / Vault / SealedSecrets，不要用 .env

# ===== 数据库（本地 docker-compose 默认值，无需改） =====
SPRING_DATASOURCE_PASSWORD=postgres

# ===== Redis（本地 docker-compose 默认值） =====
REDIS_PASSWORD=REDACTED_REDIS_PASSWORD

# ===== 阿里云 OSS（必填，从 RAM 控制台获取） =====
ALI_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALI_OSS_ACCESS_KEY_ID=LTAIxxxxxxxxxxxxxxxx
ALI_OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
ALI_OSS_BUCKET_NAME=pawmatch

# ===== AI 模型（必填） =====
# 硅基流动（Embedding / Chat）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 阿里云 DashScope / 百炼
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== JWT 签名密钥（≥256 bit / 64 hex 字符） =====
# 不填也能跑（run.sh 会用 openssl rand -hex 32 临时生成一个）
# 但每次重启 token 都会失效，建议至少本地固定一个值
# 生成方式（PowerShell）：  -join ((1..64) | ForEach-Object { '{0:x}' -f (Get-Random -Max 16) })
# 生成方式（Git Bash）：    openssl rand -hex 32
JWT_SECRET=